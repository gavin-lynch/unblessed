{
  "name": "@gavin-lynch/unblessed-contrib",
  "description": "Dashboard widgets and charts for @gavin-lynch/unblessed-core - port of blessed-contrib",
  "version": "1.0.1",
  "author": "Gavin Brady Lynch <gavin.b.lynch@gmail.com>",
  "license": "MIT",
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "registry": "https://registry.npmjs.org/"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.cjs",
    "dist/**/*.d.ts",
    "dist/**/*.d.cts",
    "dist/**/*.map",
    "LICENSE",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/gavin-lynch/unblessed.git",
    "directory": "packages/contrib"
  },
  "homepage": "https://github.com/gavin-lynch/unblessed/tree/main/packages/contrib",
  "bugs": {
    "url": "https://github.com/gavin-lynch/unblessed/issues"
  },
  "keywords": [
    "unblessed",
    "tui",
    "blessed",
    "blessed-contrib",
    "terminal",
    "ui",
    "charts",
    "dashboard",
    "widgets"
  ],
  "scripts": {
    "build": "tsup",
    "build:watch": "tsup --watch",
    "clean": "rimraf dist coverage .turbo",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint . --fix",
    "lint:check": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@gavin-lynch/unblessed-core": "workspace:*",
    "@gavin-lynch/unblessed-theme": "workspace:*",
    "chalk": "^5.0.0",
    "cli-highlight": "^2.1.11",
    "diff": "^8.0.0",
    "map-canvas": "^0.1.5",
    "marked": "^15.0.0",
    "marked-terminal": "^7.0.0",
    "picture-tuber": "^1.0.2",
    "x256": "^0.0.2"
  },
  "devDependencies": {
    "@types/marked-terminal": "^6.1.1",
    "@gavin-lynch/unblessed-node": "workspace:*",
    "@gavin-lynch/unblessed-perf": "workspace:*",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/ui": "^3.2.4",
    "tsx": "^4.20.6"
  },
  "engines": {
    "node": ">= 22.0.0"
  }
}
